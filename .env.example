# 数据库配置
# PostgreSQL 生产环境
DATABASE_URL=postgresql://username:password@localhost:5432/trading

# SQLite 开发环境（默认）
# DATABASE_URL=sqlite:///data/clawtrader.db

# Flask 配置
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# CORS 配置
ALLOWED_ORIGINS=https://trading-agent-for-dscourse.surge.sh,http://localhost:8080

# 服务端口
PORT=8001
